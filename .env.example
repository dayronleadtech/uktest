# Client-exposed vars must use the VITE_ prefix (https://vite.dev/guide/env-and-mode.html)

VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_WEGLOT=false

# Comma-separated GTM container IDs (e.g. GTM-XXXX,GTM-YYYY)
VITE_GTM_IDS=

# Weglot API key — use .env.local (gitignored), never commit real keys
VITE_WEGLOT_API_KEY=
